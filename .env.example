NODE_ENV=production
PORT=5000

# Required
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/aken?retryWrites=true&w=majority

# Required in production: set one or both
CORS_ORIGINS=https://aken.firm.in,https://www.aken.firm.in
FRONTEND_URL=https://aken.firm.in

# Auth (required if using /api/auth)
JWT_SECRET=replace-with-a-long-random-secret-min-32-characters

# Optional - quotation behavior
QUOTATION_GENERATE_PDF=true

# Optional - email notifications (preferred SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=alerts@aken.firm.in
SMTP_PASS=replace-with-smtp-password
SMTP_SECURE=false
EMAIL_FROM=A K ENGINEERING <alerts@aken.firm.in>
LEAD_ALERT_EMAILS=sales@aken.firm.in,operations@aken.firm.in

# Optional - legacy email style (if SMTP_* not used)
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@example.com
EMAIL_PASS=your-app-password

# Optional - WhatsApp webhook notifications
WHATSAPP_WEBHOOK_URL=https://your-whatsapp-gateway.example/webhook
WHATSAPP_WEBHOOK_TOKEN=replace-with-webhook-token
WHATSAPP_TIMEOUT_MS=8000
WHATSAPP_ADMIN_RECIPIENTS=919876543210,919123456789
WHATSAPP_SEND_CLIENT_ACK=true
DEFAULT_COUNTRY_CODE=91

