# =========================
# A K ENGINEERING - BACKEND
# =========================
# Copy this file to .env for local dev.
# In production (Render), set these values in Environment Variables.
#
# NEVER commit real secrets to git.

# Environment
NODE_ENV=development
PORT=5000

# MongoDB Atlas (required)
# Example:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/aken?retryWrites=true&w=majority
MONGO_URI=

# JWT secret for admin session cookie signing (required)
# Must be at least 32 chars. Use a random generator.
JWT_SECRET=

# CORS configuration (required in production)
# Comma-separated origins allowed to call the API with credentials (cookies).
# Production should include ONLY your Vercel frontend:
# CORS_ORIGINS=https://aken.firm.in
CORS_ORIGINS=http://localhost:3000

# Optional: cookie domain (recommended to leave empty for host-only cookies)
# For aken.firm.in only, keep empty.
# If you later need cross-subdomain cookies, you might set: .firm.in
COOKIE_DOMAIN=

# Admin bootstrap (recommended for production)
# This allows creating the first admin safely.
BOOTSTRAP_ADMIN_EMAIL=admin@aken.firm.in
BOOTSTRAP_SECRET=

# Optional: quotation PDF + email
QUOTATION_GENERATE_PDF=true

# Email configuration (optional)
# Choose ONE style: SMTP_* OR EMAIL_USER/EMAIL_PASS
EMAIL_FROM="A K ENGINEERING <no-reply@aken.firm.in>"

# SMTP (recommended)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Gmail-style (fallback)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# WhatsApp integration (optional, only if you use it)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# Rate limiting storage
# Default in-memory store is OK for dev.
# For production multi-instance, configure Redis (future).
